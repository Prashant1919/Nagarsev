# ──────────────────────────────────────────────────────────
# .env.local  (for local `vercel dev` — NEVER commit this file)
# Copy to .env.local and fill in real values.
# Add these SAME variables to Vercel → Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────

# Admin login credentials (hardcoded single user)
ADMIN_USERNAME=nagarsevak_admin
ADMIN_PASSWORD=YourStrongPasswordHere_ChangeThis!

# Secret for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_hex_string_at_least_48_chars

# Google Service Account JSON — paste the ENTIRE content of your
# downloaded service-account.json file as a single-line JSON string.
# Steps:
#   1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#   2. Create a service account, grant no IAM roles
#   3. Create a JSON key → download
#   4. Share your Google Sheet with the service account email (Editor access)
#   5. Minify the JSON with: node -e "const f=require('./sa.json'); console.log(JSON.stringify(f))"
#   6. Paste the output below (the whole thing as one line inside single quotes)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"...","token_uri":"..."}
